# Backend env example (Railway production-ready)
# Copy to .env (local) or configure in Railway environment variables.

PORT=5000
NODE_ENV=production

# MongoDB
MONGODB_URI=

# Auth
JWT_SECRET=
JWT_EXPIRES_IN=7d
API_KEY=

# PMS ↔ PAS integration
PMS_API_KEY=
PMS_BASE_URL=

# CORS / Client
CLIENT_URL=
CORS_ORIGINS=

# Optional: Admin subsystem
ADMIN_SUBSYSTEM_BASE_URI=
ADMIN_SUBSYSTEM_API_KEY=
ADMIN_SUBSYSTEM_NAME=Predictive
