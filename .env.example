# ═══════════════════════════════════════════════════════════════
# Pulse Prophet — Environment Template
# Copy this file to `.env` in the project ROOT and fill in real values.
# This is the ONLY .env file for the full-stack project.
# ═══════════════════════════════════════════════════════════════

# ── Server ─────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development
CORS_ORIGIN=*

# ── Database ───────────────────────────────────────────────────
MONGODB_URI=your_mongodb_uri

# ── JWT / Authentication ─────────────────────────────────────────
JWT_SECRET=your_jwt_secret
API_KEY=your_pulse_api_key
# AUTH_DEV_BYPASS=true   # ⚠️ ONLY for local dev testing; never enable in production

# ── PMS (Patient Management System) Integration ────────────────
PMS_API_KEY=your_pms_api_key
PMS_BASE_URL=https://pms-backend-kohl.vercel.app/api/v1/external
PMS_CACHE_TTL_MS=120000

# ── Admin Subsystem ────────────────────────────────────────────
ADMIN_SUBSYSTEM_BASE_URI=https://admin-subystem.onrender.com
ADMIN_SUBSYSTEM_API_KEY=your_admin_subsystem_api_key
ADMIN_SUBSYSTEM_NAME=Predictive

# ── Frontend (Vite) ────────────────────────────────────────────
# Only variables prefixed with VITE_ are exposed to the client.
VITE_API_URL=http://localhost:5000
